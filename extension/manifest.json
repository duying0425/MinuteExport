{
  "manifest_version": 3,
  "name": "Feishu Minutes Exporter",
  "version": "1.2.0",
  "description": "Export Feishu Minutes (飞书妙记) meeting transcripts to Markdown with one click. The meeting name is used as the filename.",
  "permissions": ["cookies", "downloads", "declarativeNetRequest"],
  "host_permissions": ["https://*.feishu.cn/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Feishu Minutes Exporter",
    "default_icon": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.feishu.cn/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icons/icon.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_referer",
        "enabled": true,
        "path": "rules_referer.json"
      }
    ]
  }
}
